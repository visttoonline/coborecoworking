# Copie este arquivo para .env.local e preencha os valores

# Banco de dados (SQLite no dev, Postgres no Vercel via Neon)
DATABASE_URL="file:./dev.db"

# Google Calendar API
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID_OPEN_SPACE=
GOOGLE_CALENDAR_ID_SALA_REUNIAO=
GOOGLE_CALENDAR_ID_ESTUDIO=
GOOGLE_CALENDAR_ID_SALA_GRAVACAO=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Resend (email transacional)
RESEND_API_KEY=

# WhatsApp — número com DDD e DDI, sem + ou espaços
NEXT_PUBLIC_WHATSAPP_NUMBER=5553999999999

# URL do site
NEXT_PUBLIC_SITE_URL=https://cobore.com.br
